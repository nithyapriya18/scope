'use client';

import { useState, useEffect } from 'react';
import { useRouter } from 'next/navigation';
import Link from 'next/link';
import {
  FileText,
  Plus,
  Search,
  Filter,
  TrendingUp,
  Clock,
  CheckCircle2,
  AlertCircle,
  ChevronsLeft,
  ChevronsRight,
} from 'lucide-react';
import { getCurrentUser } from '@/lib/auth';

interface Opportunity {
  id: string;
  rfpTitle: string | null;
  clientName: string | null;
  status: string;
  createdAt: string;
  rfpDeadline: string | null;
  therapeuticArea: string | null;
  budget: string | null;
  domain: string | null;
}

export default function DashboardPage() {
  const router = useRouter();
  const [searchQuery, setSearchQuery] = useState('');
  const [statusFilter, setStatusFilter] = useState<string>('all');
  const [domainFilter, setDomainFilter] = useState<string>('all');
  const [isLoading, setIsLoading] = useState(true);
  const [opportunities, setOpportunities] = useState<Opportunity[]>([]);
  const [expandedColumns, setExpandedColumns] = useState({
    title: true,
    client: true,
    domain: true,
    therapeuticArea: true,
    status: true,
    deadline: true,
    created: true,
  });
  const [stats, setStats] = useState({
    total: 0,
    inProgress: 0,
    approved: 0,
    avgResponseTime: '0',
  });

  // Fetch opportunities from API
  useEffect(() => {
    const user = getCurrentUser();
    if (!user) {
      router.push('/login');
      return;
    }

    const fetchOpportunities = async () => {
      try {
        const response = await fetch(`${process.env.NEXT_PUBLIC_BACKEND_URL}/api/opportunities`);
        if (response.ok) {
          const data = await response.json();
          setOpportunities(data.opportunities || []);

          // Calculate stats
          const total = data.opportunities?.length || 0;
          const approved = data.opportunities?.filter((o: Opportunity) => o.status === 'approved').length || 0;
          const inProgress = data.opportunities?.filter((o: Opportunity) =>
            o.status !== 'approved' && o.status !== 'intake'
          ).length || 0;

          setStats({
            total,
            inProgress,
            approved,
            avgResponseTime: '4.2 days', // TODO: Calculate from actual data
          });
        }
      } catch (error) {
        console.error('Failed to fetch opportunities:', error);
      } finally {
        setIsLoading(false);
      }
    };

    fetchOpportunities();
  }, [router]);

  if (isLoading) {
    return (
      <div className="min-h-screen bg-gray-50 dark:bg-gray-800 flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-ps-primary-600 mx-auto mb-4"></div>
          <p className="text-gray-600 dark:text-gray-300">Loading...</p>
        </div>
      </div>
    );
  }

  const filteredOpportunities = opportunities.filter((opp) => {
    const matchesSearch =
      (opp.rfpTitle?.toLowerCase().includes(searchQuery.toLowerCase()) ||
       opp.clientName?.toLowerCase().includes(searchQuery.toLowerCase())) ?? false;
    const matchesStatus = statusFilter === 'all' || opp.status === statusFilter;
    const matchesDomain = domainFilter === 'all' || opp.domain === domainFilter;
    return matchesSearch && matchesStatus && matchesDomain;
  });

  return (
    <div className="min-h-screen bg-gray-50 dark:bg-gray-900">
      <div className="container mx-auto px-4 py-8">
        {/* Header */}
        <div className="mb-8">
          <h1 className="text-3xl font-bold text-gray-900 dark:text-white mb-2">RFP Dashboard</h1>
          <p className="text-gray-600 dark:text-gray-300">Manage and track all your RFP responses</p>
        </div>

        {/* Stats Cards */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
          <StatCard
            icon={<FileText className="w-6 h-6 text-ps-primary-600 dark:text-ps-primary-400" />}
            label="Total RFPs"
            value={stats.total.toString()}
            trend={`${filteredOpportunities.length} shown`}
          />
          <StatCard
            icon={<Clock className="w-6 h-6 text-yellow-600 dark:text-yellow-400" />}
            label="In Progress"
            value={stats.inProgress.toString()}
            trend={`${Math.round((stats.inProgress / Math.max(stats.total, 1)) * 100)}% of total`}
          />
          <StatCard
            icon={<CheckCircle2 className="w-6 h-6 text-green-600 dark:text-green-400" />}
            label="Approved"
            value={stats.approved.toString()}
            trend={`${Math.round((stats.approved / Math.max(stats.total, 1)) * 100)}% win rate`}
          />
          <StatCard
            icon={<TrendingUp className="w-6 h-6 text-blue-600 dark:text-blue-400" />}
            label="Avg Response Time"
            value={stats.avgResponseTime}
            trend="Based on last 30 days"
          />
        </div>

        {/* Domain Filter Chips */}
        <div className="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-4 mb-6">
          <div className="flex items-center gap-3">
            <span className="text-sm font-medium text-gray-700 dark:text-gray-200">Domain:</span>
            <div className="flex gap-2 flex-wrap">
              <button
                onClick={() => setDomainFilter('all')}
                className={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                  domainFilter === 'all'
                    ? 'bg-ps-primary-600 text-white'
                    : 'bg-gray-100 dark:bg-gray-700 text-gray-700 hover:bg-gray-200'
                }`}
              >
                All
              </button>
              <button
                onClick={() => setDomainFilter('pharma')}
                className={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                  domainFilter === 'pharma'
                    ? 'bg-blue-600 text-white'
                    : 'bg-blue-50 text-blue-700 hover:bg-blue-100'
                }`}
              >
                Pharma
              </button>
              <button
                onClick={() => setDomainFilter('medtech')}
                className={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                  domainFilter === 'medtech'
                    ? 'bg-purple-600 text-white'
                    : 'bg-purple-50 text-purple-700 hover:bg-purple-100'
                }`}
              >
                MedTech
              </button>
              <button
                onClick={() => setDomainFilter('consumer_health')}
                className={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                  domainFilter === 'consumer_health'
                    ? 'bg-green-600 text-white'
                    : 'bg-green-50 text-green-700 hover:bg-green-100'
                }`}
              >
                Consumer Health
              </button>
            </div>
          </div>
        </div>

        {/* Actions Bar */}
        <div className="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-4 mb-6">
          <div className="flex flex-col md:flex-row gap-4 items-center justify-between">
            {/* Search */}
            <div className="relative flex-1 w-full md:w-auto">
              <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-gray-400" />
              <input
                type="text"
                placeholder="Search RFPs by title or client..."
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                className="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-ps-primary-500"
              />
            </div>

            {/* Filters */}
            <div className="flex gap-3 w-full md:w-auto">
              <select
                value={statusFilter}
                onChange={(e) => setStatusFilter(e.target.value)}
                className="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-ps-primary-500"
              >
                <option value="all">All Status</option>
                <option value="intake">Intake</option>
                <option value="brief_extract">Brief Extraction</option>
                <option value="clarification">Clarification</option>
                <option value="scope_build">Scope Building</option>
                <option value="document_gen">Document Generation</option>
                <option value="approved">Approved</option>
              </select>

              <Link
                href="/opportunities/new"
                className="flex items-center gap-2 bg-ps-primary-600 hover:bg-ps-primary-700 text-white px-6 py-2 rounded-lg font-medium transition-colors whitespace-nowrap"
              >
                <Plus className="w-5 h-5" />
                New RFP
              </Link>
            </div>
          </div>
        </div>

        {/* Opportunities Table */}
        <div className="bg-white dark:bg-gray-800 rounded-lg shadow-sm overflow-hidden">
          {filteredOpportunities.length === 0 ? (
            <div className="p-12 text-center">
              <AlertCircle className="w-12 h-12 text-gray-400 mx-auto mb-4" />
              <h3 className="text-lg font-medium text-gray-900 mb-2">No RFPs found</h3>
              <p className="text-gray-600 mb-6">
                {searchQuery || statusFilter !== 'all'
                  ? 'Try adjusting your search or filters'
                  : 'Get started by uploading your first RFP'}
              </p>
              <Link
                href="/opportunities/new"
                className="inline-flex items-center gap-2 bg-ps-primary-600 hover:bg-ps-primary-700 text-white px-6 py-3 rounded-lg font-medium transition-colors"
              >
                <Plus className="w-5 h-5" />
                Upload First RFP
              </Link>
            </div>
          ) : (
            <div className="overflow-x-auto">
              <table className="w-full table-fixed">
                <thead className="bg-gray-50 dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
                  <tr>
                    <th className={`px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider ${expandedColumns.title ? 'w-80' : 'w-48'}`}>
                      <div className="flex items-center justify-between gap-2">
                        <span>RFP Title</span>
                        <button
                          onClick={() => setExpandedColumns(prev => ({ ...prev, title: !prev.title }))}
                          className="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
                          title={expandedColumns.title ? "Contract column" : "Expand column"}
                        >
                          {expandedColumns.title ? <ChevronsLeft className="w-4 h-4" /> : <ChevronsRight className="w-4 h-4" />}
                        </button>
                      </div>
                    </th>
                    <th className={`px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider ${expandedColumns.client ? 'w-64' : 'w-32'}`}>
                      <div className="flex items-center justify-between gap-2">
                        <span>Client</span>
                        <button
                          onClick={() => setExpandedColumns(prev => ({ ...prev, client: !prev.client }))}
                          className="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300"
                          title={expandedColumns.client ? "Contract column" : "Expand column"}
                        >
                          {expandedColumns.client ? <ChevronsLeft className="w-4 h-4" /> : <ChevronsRight className="w-4 h-4" />}
                        </button>
                      </div>
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-32">
                      Domain
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-40">
                      Therapeutic Area
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-40">
                      Status
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-32">
                      Deadline
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-32">
                      Created
                    </th>
                    <th className="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider w-32">
                      Actions
                    </th>
                  </tr>
                </thead>
                <tbody className="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                  {filteredOpportunities.map((opportunity) => (
                    <OpportunityRow key={opportunity.id} opportunity={opportunity} expandedColumns={expandedColumns} />
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

function StatCard({
  icon,
  label,
  value,
  trend,
}: {
  icon: React.ReactNode;
  label: string;
  value: string;
  trend: string;
}) {
  return (
    <div className="bg-white dark:bg-gray-800 rounded-lg shadow-sm p-6 border border-gray-100 dark:border-gray-700">
      <div className="flex items-center justify-between mb-4">
        <div className="p-2 bg-gray-50 dark:bg-gray-700 rounded-lg">{icon}</div>
      </div>
      <div className="text-2xl font-bold text-gray-900 dark:text-white mb-1">{value}</div>
      <div className="text-sm text-gray-600 dark:text-gray-300 mb-1">{label}</div>
      <div className="text-xs text-gray-500 dark:text-gray-400">{trend}</div>
    </div>
  );
}

function OpportunityRow({ opportunity, expandedColumns }: { opportunity: Opportunity; expandedColumns: any }) {
  const statusConfig = {
    intake: { label: 'Intake', color: 'bg-gray-100 dark:bg-gray-700 text-gray-700' },
    brief_extract: { label: 'Brief Extraction', color: 'bg-blue-100 text-blue-700' },
    gap_analysis: { label: 'Gap Analysis', color: 'bg-yellow-100 text-yellow-700' },
    clarification: { label: 'Clarification', color: 'bg-orange-100 text-orange-700' },
    scope_build: { label: 'Scope Building', color: 'bg-purple-100 text-purple-700' },
    sample_plan: { label: 'Sample Planning', color: 'bg-indigo-100 text-indigo-700' },
    hcp_shortlist: { label: 'HCP Shortlist', color: 'bg-pink-100 text-pink-700' },
    wbs_estimate: { label: 'WBS Estimation', color: 'bg-cyan-100 text-cyan-700' },
    pricing: { label: 'Pricing', color: 'bg-teal-100 text-teal-700' },
    document_gen: { label: 'Document Generation', color: 'bg-green-100 text-green-700' },
    approved: { label: 'Approved', color: 'bg-emerald-100 text-emerald-700' },
  };

  const status = statusConfig[opportunity.status as keyof typeof statusConfig] || statusConfig.intake;

  const formatDate = (dateString: string | null) => {
    if (!dateString) return '-';
    try {
      return new Date(dateString).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      });
    } catch {
      return dateString;
    }
  };

  return (
    <tr className="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
      <td className="px-6 py-4">
        <div className="text-sm font-medium text-gray-900 dark:text-white break-words">
          {opportunity.rfpTitle || 'Untitled RFP'}
        </div>
      </td>
      <td className="px-6 py-4">
        <div className="text-sm text-gray-900 dark:text-white break-words">{opportunity.clientName || '-'}</div>
      </td>
      <td className="px-6 py-4">
        {opportunity.domain === 'pharma' && (
          <span className="px-2 py-1 inline-flex text-xs leading-5 font-medium rounded-full bg-blue-100 text-blue-700">
            Pharma
          </span>
        )}
        {opportunity.domain === 'medtech' && (
          <span className="px-2 py-1 inline-flex text-xs leading-5 font-medium rounded-full bg-purple-100 text-purple-700">
            MedTech
          </span>
        )}
        {opportunity.domain === 'consumer_health' && (
          <span className="px-2 py-1 inline-flex text-xs leading-5 font-medium rounded-full bg-green-100 text-green-700">
            Consumer Health
          </span>
        )}
        {(!opportunity.domain || opportunity.domain === 'unknown') && (
          <span className="px-2 py-1 inline-flex text-xs leading-5 font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-200">
            Unknown
          </span>
        )}
      </td>
      <td className="px-6 py-4">
        <span className="px-2 py-1 inline-flex text-xs leading-5 font-medium rounded-full bg-gray-100 dark:bg-gray-700 text-gray-700 dark:text-gray-200 break-words">
          {opportunity.therapeuticArea || 'Not specified'}
        </span>
      </td>
      <td className="px-6 py-4">
        <span className={`px-2 py-1 inline-flex text-xs leading-5 font-medium rounded-full ${status.color}`}>
          {status.label}
        </span>
      </td>
      <td className="px-6 py-4 text-sm text-gray-900 dark:text-white">
        {formatDate(opportunity.rfpDeadline)}
      </td>
      <td className="px-6 py-4 text-sm text-gray-500 dark:text-gray-400">
        {formatDate(opportunity.createdAt)}
      </td>
      <td className="px-6 py-4 text-right text-sm font-medium">
        <Link
          href={`/opportunities/${opportunity.id}`}
          className="text-ps-primary-600 hover:text-ps-primary-900 dark:hover:text-ps-primary-400 transition-colors"
        >
          View Details
        </Link>
      </td>
    </tr>
  );
}
